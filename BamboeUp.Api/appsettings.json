{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "sqlConnection": "Server=localhost;Database=Dev.BamboeHR;User Id=sa;Password=123;Encrypt=False;",
    "AuditConnection": "Server=localhost;Database=BamboeUpAuditDB;User Id=sa;Password=123;Encrypt=False;"
  },
  "JwtSettings": {
    "ValidIssuer": "BamboeUp.Api",
    "ValidAudience": "BamboeUp.App",
    "Expires": 60,
    "SecretKey": "this_is_a_long_secret_key_123456"
  },
  "AdminRegistrySettings": {
    "FilePath": "App_Data/admin.registry.enc",
    "EncryptionKey": "dev_admin_registry_key_change_in_production_32"
  },
  "UseScopedMasterData": true,
  "AllowedHosts": "*",
  "CorsSettings": {
    "AllowedOrigins": [
      "http://localhost:5139",
      "https://localhost:5139",
      "http://localhost:5000",
      "https://localhost:5000"
    ]
  },
  "FileStorage": {
    "UploadRoot": "Uploads",
    "AllowedExtensions": [ ".jpg", ".jpeg", ".png", ".gif", ".webp", ".pdf", ".doc", ".docx", ".xls", ".xlsx", ".mp4", ".mp3", ".zip" ],
    "MaximumFileSize": 10485760,
    "GenerateThumbnail": true,
    "ThumbnailWidth": 150,
    "ThumbnailHeight": 150,
    "StorageProvider": "Local"
  }
